{
    "name": "tomado-be",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "nodemon --exec \"node --loader ts-node/esm\" src/index.ts",
        "build": "npx prisma generate && tsc && mkdir -p dist/swagger && cp src/swagger/openapi.yaml dist/swagger/",
        "start": "node dist/index.js",
        "prepare": "node -e \"if (require('fs').existsSync('.git')) { require('child_process').spawnSync('npx', ['husky', 'install'], { stdio: 'inherit' }) }\"",
        "lint": "eslint .",
        "format": "prettier --write .",
        "generate": "npx prisma generate"
    },
    "lint-staged": {
        "*.{js,ts,json,md}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@prisma/client": "^6.0.0",
        "@supabase/supabase-js": "^2.99.3",
        "@types/multer": "^2.1.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "yamljs": "^0.3.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/node": "^20.10.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.6",
        "@types/yamljs": "^0.2.34",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^15.0.0",
        "husky": "^9.0.0",
        "lint-staged": "^16.0.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.2.0",
        "prisma": "^6.0.0",
        "ts-node": "^10.9.1",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.0.0"
    }
}
